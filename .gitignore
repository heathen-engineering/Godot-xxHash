# Godot 4+ specific ignores
.godot/
.nomedia

# Godot-specific ignores
.import/
export.cfg
export_credentials.cfg
*.tmp

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# CMake build directory
addons/FoundationXxHash/build/

# Compiled GDExtension binaries — never committed. CI builds and packages these;
# for local dev, build from source (see README) or grab a Release zip.
addons/FoundationXxHash/bin/

# No dot-prefixed folder is ever checked in to this repo (IDE project files, local agent tool
# state, whatever creates it). Only .github/ is exempted, since its workflow files are real,
# load-bearing repo infrastructure, not local tool state.
.*/
!/.github/
!/.github/**
